{
  "name": "@booger/shared",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --clean --out-dir dist --watch",
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@booger/game": "workspace:*",
    "@colyseus/schema": "^4.0.19",
    "zod": "^4.3.6"
  }
}
